# Chatbot LLM configuration (optional).
# If OPENAI_API_KEY is NOT set, the chatbot automatically falls back to a
# built-in rule-based assistant that answers from Aditya's bio. No key required.

# Your API key (OpenAI or any OpenAI-compatible provider).
OPENAI_API_KEY=

# Optional: override the base URL to use another OpenAI-compatible provider
# (e.g. Groq: https://api.groq.com/openai/v1, OpenRouter: https://openrouter.ai/api/v1).
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: model name. Defaults to gpt-4o-mini.
# OPENAI_MODEL=gpt-4o-mini
